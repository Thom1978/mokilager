# MOKILager Environment Configuration
# Kopieren Sie diese Datei als .env und passen Sie die Werte an

# Datenbank
MYSQL_ROOT_PASSWORD=sicher_aendern_root
MYSQL_PASSWORD=sicher_aendern

# App
APP_PORT=3000
SESSION_SECRET=ein_langer_zufaelliger_string_hier
APP_URL=http://localhost:3000

# E-Mail (für Leiherinnerungen)
SMTP_HOST=smtp.ihranbieter.at
SMTP_PORT=587
SMTP_USER=noreply@ihrserver.at
SMTP_PASS=email_passwort
SMTP_FROM=MOKILager <noreply@ihrserver.at>

# GitHub Container Registry (automatisch gesetzt durch GitHub Actions)
# GITHUB_REPOSITORY=ihrgithubname/mokilager
